# Copy this to .env and fill in your values

# Server
PORT=3001
BASE_URL=http://localhost:3001
NODE_ENV=development

# JWT — change BOTH of these to random 32+ char strings!
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string_32_chars

# Google OAuth — get from https://console.cloud.google.com
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
